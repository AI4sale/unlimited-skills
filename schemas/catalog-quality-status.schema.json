{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unlimited Skills catalog quality status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_type",
    "quality_status",
    "manifest_signature"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "manifest_type": { "type": "string", "const": "catalog-quality-status" },
    "quality_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "quality_grade", "score_band", "last_eval_at", "blockers", "warnings", "compatibility_notes", "deprecation_status", "retired", "feedback_issue_categories", "install_risk", "install_allowed"],
      "properties": {
        "item_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,191}$" },
        "quality_grade": { "type": "string", "enum": ["a", "b", "c", "d", "f", "blocked", "unknown"] },
        "score_band": { "type": "string" },
        "last_eval_at": { "type": "string" },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "compatibility_notes": { "type": "array", "items": { "type": "string" } },
        "deprecation_status": { "type": "string", "enum": ["active", "deprecated", "retired", "blocked"] },
        "retired": { "type": "boolean" },
        "feedback_issue_categories": { "type": "array", "items": { "type": "string" } },
        "install_risk": { "type": "string", "enum": ["low", "warning", "blocked", "unknown"] },
        "install_allowed": { "type": "boolean" }
      }
    },
    "manifest_signature": { "type": "object" }
  }
}
