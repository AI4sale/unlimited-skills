{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unlimited Skills catalog response",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "catalog", "total_collections", "total_skills"],
  "properties": {
    "schema_version": { "type": "integer" },
    "request_id": { "type": "string" },
    "server_time": { "type": "string", "format": "date-time" },
    "plan": { "type": "string" },
    "features_enabled": { "type": "array", "items": { "type": "string" } },
    "total_collections": { "type": "integer", "minimum": 0 },
    "total_skills": { "type": "integer", "minimum": 0 },
    "catalog": {
      "type": "object",
      "required": ["collections"],
      "properties": {
        "collections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["collection", "display_name", "description", "version", "visibility", "skill_count", "compatible_agents", "min_client_version", "update_available", "tags", "release_notes", "updated_at"],
            "properties": {
              "collection": { "type": "string" },
              "display_name": { "type": "string" },
              "description": { "type": "string" },
              "version": { "type": "string" },
              "visibility": { "type": "string", "enum": ["registered-community", "team-free", "pro", "enterprise"] },
              "skill_count": { "type": "integer", "minimum": 0 },
              "compatible_agents": { "type": "array", "items": { "type": "string" } },
              "min_client_version": { "type": "string" },
              "max_client_version": { "type": "string" },
              "platforms": { "type": "array", "items": { "type": "string" } },
              "skill_format": { "type": "string" },
              "update_available": { "type": "boolean" },
              "installed_version": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } },
              "release_notes": { "type": "string" },
              "updated_at": { "type": "string", "format": "date-time" },
              "deprecation": { "type": "object" }
            }
          }
        }
      }
    }
  }
}
