{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unlimited Skills policy-aware recommendation decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_type",
    "fixture_only",
    "preview_only",
    "automatic_install",
    "automatic_update",
    "automatic_remove",
    "automatic_telemetry",
    "hosted_query_forwarding",
    "skill_rewriting",
    "full_catalog_distribution",
    "outcomes",
    "denial_outcomes",
    "decisions"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "manifest_type": { "type": "string", "const": "recommendation-decision" },
    "fixture_only": { "type": "boolean", "const": true },
    "preview_only": { "type": "boolean", "const": true },
    "automatic_install": { "type": "boolean", "const": false },
    "automatic_update": { "type": "boolean", "const": false },
    "automatic_remove": { "type": "boolean", "const": false },
    "automatic_telemetry": { "type": "boolean", "const": false },
    "hosted_query_forwarding": { "type": "boolean", "const": false },
    "skill_rewriting": { "type": "boolean", "const": false },
    "full_catalog_distribution": { "type": "boolean", "const": false },
    "skill_bodies_included": { "type": "boolean", "const": false },
    "prompts_included": { "type": "boolean", "const": false },
    "task_text_included": { "type": "boolean", "const": false },
    "local_paths_included": { "type": "boolean", "const": false },
    "repo_paths_included": { "type": "boolean", "const": false },
    "customer_data_included": { "type": "boolean", "const": false },
    "tokens_included": { "type": "boolean", "const": false },
    "proofs_included": { "type": "boolean", "const": false },
    "private_keys_included": { "type": "boolean", "const": false },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "allow_preview",
          "allow_install",
          "allow_update_preview",
          "warn_before_install",
          "deny_install",
          "deny_update",
          "require_registration",
          "require_entitlement",
          "require_policy_override",
          "local_only",
          "unsupported"
        ]
      }
    },
    "denial_outcomes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "deny_install",
          "deny_update",
          "require_registration",
          "require_entitlement",
          "require_policy_override",
          "local_only",
          "unsupported"
        ]
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case",
          "item_id",
          "source_type",
          "status",
          "outcome",
          "reason",
          "next_command",
          "recommended_channel",
          "installed_version",
          "recommended_version",
          "fixture_only",
          "preview_only",
          "automatic_install",
          "automatic_update",
          "automatic_remove",
          "automatic_telemetry",
          "hosted_query_forwarding",
          "skill_rewriting",
          "full_catalog_distribution",
          "will_install",
          "will_update",
          "will_remove"
        ],
        "properties": {
          "case": { "type": "string", "minLength": 1 },
          "item_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,191}$" },
          "source_type": {
            "type": "string",
            "enum": ["local_mit", "hosted_official", "community_catalog", "private_team_pack"]
          },
          "status": { "type": "string", "minLength": 1 },
          "outcome": {
            "type": "string",
            "enum": [
              "allow_preview",
              "allow_install",
              "allow_update_preview",
              "warn_before_install",
              "deny_install",
              "deny_update",
              "require_registration",
              "require_entitlement",
              "require_policy_override",
              "local_only",
              "unsupported"
            ]
          },
          "reason": { "type": "string", "minLength": 1 },
          "next_command": { "type": "string", "minLength": 1 },
          "refusal_code": {
            "type": "string",
            "enum": [
              "registration_required",
              "entitlement_denied",
              "policy_denied",
              "blocked_item",
              "retired_item",
              "low_score",
              "wrong_channel",
              "wrong_agent",
              "unsigned_metadata",
              "local_only"
            ]
          },
          "owner": { "type": "string" },
          "action": { "type": "string" },
          "fallback": { "type": "string" },
          "recommended_channel": { "type": "string" },
          "installed_version": { "type": "string" },
          "recommended_version": { "type": "string" },
          "fixture_only": { "type": "boolean", "const": true },
          "preview_only": { "type": "boolean", "const": true },
          "automatic_install": { "type": "boolean", "const": false },
          "automatic_update": { "type": "boolean", "const": false },
          "automatic_remove": { "type": "boolean", "const": false },
          "automatic_telemetry": { "type": "boolean", "const": false },
          "hosted_query_forwarding": { "type": "boolean", "const": false },
          "skill_rewriting": { "type": "boolean", "const": false },
          "full_catalog_distribution": { "type": "boolean", "const": false },
          "skill_bodies_included": { "type": "boolean", "const": false },
          "prompts_included": { "type": "boolean", "const": false },
          "task_text_included": { "type": "boolean", "const": false },
          "local_paths_included": { "type": "boolean", "const": false },
          "repo_paths_included": { "type": "boolean", "const": false },
          "customer_data_included": { "type": "boolean", "const": false },
          "tokens_included": { "type": "boolean", "const": false },
          "proofs_included": { "type": "boolean", "const": false },
          "private_keys_included": { "type": "boolean", "const": false },
          "will_install": { "type": "boolean", "const": false },
          "will_update": { "type": "boolean", "const": false },
          "will_remove": { "type": "boolean", "const": false }
        }
      }
    }
  }
}
