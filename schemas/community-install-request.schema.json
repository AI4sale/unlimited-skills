{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unlimited Skills community install request",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "install_id", "client", "item_id", "dry_run"],
  "properties": {
    "schema_version": { "type": "integer" },
    "install_id": { "type": "string" },
    "client": { "type": "object" },
    "item_id": { "type": "string" },
    "target_collection": { "type": "string" },
    "dry_run": { "type": "boolean" },
    "force": { "type": "boolean" },
    "collections": { "type": "object" }
  }
}
