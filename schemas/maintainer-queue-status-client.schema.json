{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unlimited Skills maintainer queue status client response",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_type", "manifest_signature"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "manifest_type": { "type": "string", "const": "maintainer-queue-status-client" },
    "queue_status": { "$ref": "#/$defs/status" },
    "queue_summary": { "$ref": "#/$defs/summary" },
    "manifest_signature": { "type": "object" }
  },
  "oneOf": [
    { "required": ["queue_status"] },
    { "required": ["queue_summary"] }
  ],
  "$defs": {
    "countMap": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "queue_status",
        "severity_summary",
        "maintainer_state",
        "fixed_pending_eval_evidence_ref",
        "eval_gate_ref",
        "recommended_user_action"
      ],
      "properties": {
        "item_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,191}$" },
        "queue_status": { "type": "string" },
        "severity_summary": { "$ref": "#/$defs/countMap" },
        "maintainer_state": { "type": "string" },
        "fixed_pending_eval_evidence_ref": { "type": "string" },
        "eval_gate_ref": { "type": "string" },
        "recommended_user_action": { "type": "string", "enum": ["none", "wait_for_eval", "review_before_update", "update_when_available", "avoid_or_remove"] },
        "issue_categories": { "type": "array", "items": { "type": "string" } },
        "updated_at": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_count", "queue_status_counts", "severity_summary", "issue_categories"],
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "queue_status_counts": { "$ref": "#/$defs/countMap" },
        "severity_summary": { "$ref": "#/$defs/countMap" },
        "issue_categories": { "type": "array", "items": { "type": "string" } },
        "maintainer_state_counts": { "$ref": "#/$defs/countMap" },
        "fixed_pending_eval_count": { "type": "integer", "minimum": 0 },
        "blocked_eval_gate_count": { "type": "integer", "minimum": 0 },
        "recommended_user_actions": { "$ref": "#/$defs/countMap" }
      }
    }
  }
}
