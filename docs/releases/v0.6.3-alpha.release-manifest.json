  "learning_loop_surfaces": [
    {
      "tier": "free",
      "commands": [
        "unlimited-skills learning doctor",
        "unlimited-skills improvement-candidates",
        "unlimited-skills apply-candidate --dry-run <candidate-id>",
        "python scripts/verify-learning-feedback-contract.py",
        "python scripts/verify-learning-loop-closed-loop-proof.py"
      ],
      "artifacts": [
        "privacy-safe candidate JSON",
        "non-mutating dry-run preview",
        "feedback contract report",
        "closed-loop dry-run proof"
      ]
    },
    {
      "tier": "registered",
      "commands": [
        "unlimited-skills learning export --out registered-learning-export.json --json-status"
      ],
      "artifacts": [
        "registered-learning-export.json"
      ]
    },
    {
      "tier": "team",
      "commands": [
        "unlimited-skills learning team-rollup --input registered-learning-export.json --out team-learning-rollup.json --json-status"
      ],
      "artifacts": [
        "team-learning-rollup.json"
      ]
    },
    {
      "tier": "business",
      "commands": [
        "unlimited-skills learning admin-export --input team-learning-rollup.json --json business-learning-admin.json --csv business-learning-admin.csv"
      ],
      "artifacts": [
        "business-learning-admin.json",
        "business-learning-admin.csv"
      ]
    },
    {
      "tier": "enterprise",
      "commands": [
        "unlimited-skills learning evidence-pack --input business-learning-admin.json --out enterprise-learning-evidence-pack",
        "unlimited-skills learning verify-evidence-pack --input enterprise-learning-evidence-pack --json"
      ],
      "artifacts": [
        "enterprise-learning-evidence-pack/manifest.json",
        "enterprise-learning-evidence-pack/non-mutation-proof.json",
        "enterprise-learning-evidence-pack/privacy-proof.json"
      ],
      "fail_closed": [
        "tampered evidence pack verification returns non-zero and ok=false"
      ]
    }
  ],
