{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit.py\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pre_compact.py\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre_compact.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
